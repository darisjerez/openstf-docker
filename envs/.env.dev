# Dev environment (infra-only, no real devices)
ENV=dev
COMPOSE_PROJECT_NAME=stf-dev

# Server
PUBLIC_IP=${PUBLIC_IP}

# Ports (offset from prod)
NGINX_PORT=8880
STF_PORT=7200
STF_WS_PORT=7210
RETHINKDB_ADMIN_PORT=8180
RETHINKDB_DRIVER_PORT=28115
EXPORTER_PORT=9205
HEALER_PORT=9206
MONITOR_PORT=9207
PROMETHEUS_PORT=9190
GRAFANA_PORT=3100

# Volume prefixes (to isolate data)
RETHINKDB_VOLUME=stf-dev-rethinkdb-data
GRAFANA_VOLUME=stf-dev-grafana-data
