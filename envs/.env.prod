# Production environment
ENV=prod
COMPOSE_PROJECT_NAME=stf-prod

# Server
PUBLIC_IP=${PUBLIC_IP}

# Ports
NGINX_PORT=80
STF_PORT=7100
STF_WS_PORT=7110
RETHINKDB_ADMIN_PORT=8080
RETHINKDB_DRIVER_PORT=28015
EXPORTER_PORT=9105
HEALER_PORT=9106
MONITOR_PORT=9107
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Volume prefixes (to isolate data)
RETHINKDB_VOLUME=stf-prod-rethinkdb-data
GRAFANA_VOLUME=stf-prod-grafana-data
